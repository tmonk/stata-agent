
. *============================================================================
> ===
. *  BURIED-ERROR DO-FILE
. *  Demonstrates: set trace on + capture noisily + many post-error commands
. *  =  the real error is NOT at the bottom of the log.
. *
. *  Run:  /Applications/StataNow/StataSE.app/Contents/MacOS/stata-se -b do big
> _trace_with_buried_error.do
. *============================================================================
> ===
. 
. clear all

. set more off

. set trace on

. 
. display "=== PREAMBLE ==="
=== PREAMBLE ===

. forvalues i = 1/10 {
  2.     quietly generate double g`i' = runiform()
  3.     quietly summarize g`i'
  4.     display "preamble `i'"
  5. }
- forvalues i = 1/10 {
- quietly generate double g`i' = runiform()
= quietly generate double g1 = runiform()
- quietly summarize g`i'
= quietly summarize g1
- display "preamble `i'"
= display "preamble 1"
preamble 1
- }
- quietly generate double g`i' = runiform()
= quietly generate double g2 = runiform()
- quietly summarize g`i'
= quietly summarize g2
- display "preamble `i'"
= display "preamble 2"
preamble 2
- }
- quietly generate double g`i' = runiform()
= quietly generate double g3 = runiform()
- quietly summarize g`i'
= quietly summarize g3
- display "preamble `i'"
= display "preamble 3"
preamble 3
- }
- quietly generate double g`i' = runiform()
= quietly generate double g4 = runiform()
- quietly summarize g`i'
= quietly summarize g4
- display "preamble `i'"
= display "preamble 4"
preamble 4
- }
- quietly generate double g`i' = runiform()
= quietly generate double g5 = runiform()
- quietly summarize g`i'
= quietly summarize g5
- display "preamble `i'"
= display "preamble 5"
preamble 5
- }
- quietly generate double g`i' = runiform()
= quietly generate double g6 = runiform()
- quietly summarize g`i'
= quietly summarize g6
- display "preamble `i'"
= display "preamble 6"
preamble 6
- }
- quietly generate double g`i' = runiform()
= quietly generate double g7 = runiform()
- quietly summarize g`i'
= quietly summarize g7
- display "preamble `i'"
= display "preamble 7"
preamble 7
- }
- quietly generate double g`i' = runiform()
= quietly generate double g8 = runiform()
- quietly summarize g`i'
= quietly summarize g8
- display "preamble `i'"
= display "preamble 8"
preamble 8
- }
- quietly generate double g`i' = runiform()
= quietly generate double g9 = runiform()
- quietly summarize g`i'
= quietly summarize g9
- display "preamble `i'"
= display "preamble 9"
preamble 9
- }
- quietly generate double g`i' = runiform()
= quietly generate double g10 = runiform()
- quietly summarize g`i'
= quietly summarize g10
- display "preamble `i'"
= display "preamble 10"
preamble 10
- }

. display "=== PREAMBLE END ==="
=== PREAMBLE END ===

. 
. 
. * ------------------------------------------------------------------
. *  Program: error in iteration 2, lots of post-error output
. * ------------------------------------------------------------------
. 
. capture program drop demo

. program define demo
  1.     version 18
  2.     args n
  3. 
.     display _newline ">>> ITERATION `n' <<<"
  4. 
.     * Generate data
.     quietly drop _all
  5.     set obs 30
  6.     generate double y = rnormal()
  7.     generate double x = y * 0.7 + rnormal()
  8.     summarize y x
  9.     quietly regress y x
 10. 
.     * ===== THE BURIED ERROR (only in iteration 2) =====
.     if `n' == 2 {
 11.         display as error ">>> PRODUCING BURIED ERROR <<<"
 12.         capture noisily confirm variable __nonexist_xyz__
 13.         if _rc != 0 {
 14.             display as error "Caught rc=`_rc', continuing..."
 15.         }
 16.     }
 17. 
.     * Post-error work (more trace = pushes error upward)
.     forvalues j = 1/8 {
 18.         quietly generate double r_`n'_`j' = runiform()
 19.         quietly summarize r_`n'_`j'
 20.         display "  post-error var `j' done"
 21.     }
 22.     quietly regress y x
 23.     predict double yh`n'
 24.     summarize yh`n'
 25.     display "Iteration `n' complete"
 26. end

. 
